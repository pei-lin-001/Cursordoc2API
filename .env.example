# Cursor Docs OpenAI Compatible bridge
CURSORDOCS_OPENAI_HOST=127.0.0.1
CURSORDOCS_OPENAI_PORT=8790
CURSORDOCS_OPENAI_API_KEY=
CURSORDOCS_UPSTREAM_BASE_URL=https://cursor.com
CURSORDOCS_DEFAULT_MODEL=anthropic/claude-sonnet-4.6
CURSORDOCS_MODELS_DISCOVERY_PATH=/cn/docs
CURSORDOCS_REQUEST_TIMEOUT_MS=120000
CURSORDOCS_MODELS_CACHE_TTL_MS=300000
CURSORDOCS_FETCH_DYNAMIC_MODELS=true
CURSORDOCS_INCLUDE_DEFAULT_CONTEXT=true
CURSORDOCS_DEFAULT_CONTEXT_PATHS=/docs/
CURSORDOCS_EXPOSED_MODELS=Sonnet 4.6=anthropic/claude-sonnet-4.6,GPT-5.1 Codex Mini=openai/gpt-5.1-codex-mini,Gemini 3 Flash=google/gemini-3-flash
CURSORDOCS_MIRROR_REASONING_TO_CONTENT=false

# Upstream probe / reasoning inspection
CURSORDOCS_PROBE_BASE_URL=https://cursor.com
CURSORDOCS_PROBE_DISCOVERY_PATH=/cn/docs
CURSORDOCS_PROBE_REASONING_MODEL=openai/gpt-5.1-codex-mini
CURSORDOCS_PROBE_REQUEST_TIMEOUT_MS=120000
# Optional: only useful if you somehow obtained the real Fernet key.
CURSORDOCS_REASONING_FERNET_KEY=

# Stress test
CURSORDOCS_STRESS_PORT=8830
CURSORDOCS_STRESS_BASE_URL=http://127.0.0.1:8830
